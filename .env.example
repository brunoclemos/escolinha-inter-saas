# Auth.js (NextAuth v5) — gere com: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — crie em https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Allowlist de e-mails autorizados (separados por vírgula)
# Deixe vazio para liberar QUALQUER conta Google (modo prototipo aberto).
AUTH_ALLOWED_EMAILS=
